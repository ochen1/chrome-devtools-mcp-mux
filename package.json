{
  "name": "chrome-devtools-mcp-mux",
  "version": "0.2.0",
  "description": "Drop-in chrome-devtools-mcp multiplexer: lets multiple MCP clients share one Chrome instance and profile, with per-client tab ownership so they don't step on each other's tabs.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Oliver Chen",
  "homepage": "https://github.com/ochen1/chrome-devtools-mcp-mux#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ochen1/chrome-devtools-mcp-mux.git"
  },
  "bugs": {
    "url": "https://github.com/ochen1/chrome-devtools-mcp-mux/issues"
  },
  "keywords": [
    "mcp",
    "chrome-devtools",
    "chrome-devtools-mcp",
    "multiplexer",
    "claude-code",
    "puppeteer"
  ],
  "bin": {
    "cdmcp-mux": "dist/bin/cdmcp-mux.js"
  },
  "files": [
    "dist",
    "README.md",
    "DEMO.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chrome-devtools-mcp": "0.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0"
  }
}
